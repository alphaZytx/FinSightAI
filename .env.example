APP_NAME=FinSightAI
ENV=development
API_HOST=0.0.0.0
API_PORT=8000
MONGO_URI=mongodb://localhost:27017
MONGO_DB=finsight_ai
LLM_PROVIDER=groq
LLM_API_KEY=replace_me
GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=text-embedding-model
UPLOAD_DIR=storage/raw
REPORT_DIR=storage/reports
CORS_ORIGINS_STR=http://localhost:5173,http://localhost:5174
# Auth / JWT — replace JWT_SECRET_KEY with a strong random string in production
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
